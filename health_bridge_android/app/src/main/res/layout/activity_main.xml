<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#05060F"
    tools:context=".MainActivity">

    <!-- ── Tab 1: WebView Layer (Secondary) ── -->
    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomNavigation"
        android:visibility="visible" />



    <!-- ── Tab 3: Security Inbox ── -->
    <LinearLayout
        android:id="@+id/layoutAlerts"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomNavigation"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="gone">

        <Button
            android:id="@+id/btnLiveCheckin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#00E5FF"
            android:text="🎥 Request Live Check-in"
            android:textColor="#05060F"
            android:textStyle="bold"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Security Incident History"
            android:textColor="#64748B"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/layoutIncidentsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </ScrollView>

    </LinearLayout>

    <!-- ── Tab 4: Missions Monitor ── -->
    <ScrollView
        android:id="@+id/layoutMissions"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomNavigation"
        android:fillViewport="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Active Mission Progress"
                android:textColor="#64748B"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <!-- Empty Placeholder -->
            <TextView
                android:id="@+id/textNoMissions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:gravity="center"
                android:text="No active mission currently running."
                android:textColor="#64748B"
                android:textSize="14sp"
                android:visibility="visible" />

            <!-- Mission Details Card -->
            <LinearLayout
                android:id="@+id/cardActiveMission"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_background"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="gone"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/missionGoal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Goal: "
                    android:textColor="#F1F5F9"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/missionStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Status: "
                    android:textColor="#00E5FF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/missionStepsTrace"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:text="Steps Graph:\n"
                    android:textColor="#A3B8CC"
                    android:textSize="11sp" />

            </LinearLayout>

            <!-- Mission Controls -->
            <LinearLayout
                android:id="@+id/layoutMissionControls"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:visibility="gone">

                <Button
                    android:id="@+id/btnPauseMission"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginRight="4dp"
                    android:backgroundTint="#E59866"
                    android:text="Pause"
                    android:textColor="#05060F"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnResumeMission"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="2dp"
                    android:backgroundTint="#00E5FF"
                    android:text="Resume"
                    android:textColor="#05060F"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnCancelMission"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginLeft="4dp"
                    android:backgroundTint="#EF4444"
                    android:text="Cancel"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- ── Tab 5: Approval Queue ── -->
    <LinearLayout
        android:id="@+id/layoutApprovals"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomNavigation"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Safety Approval Queue"
            android:textColor="#64748B"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <!-- Placeholder when empty -->
        <TextView
            android:id="@+id/textNoApprovals"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:gravity="center"
            android:text="No pending approval requests. System is safe."
            android:textColor="#64748B"
            android:textSize="14sp"
            android:visibility="visible" />

        <!-- Pending Approval Card -->
        <LinearLayout
            android:id="@+id/cardPendingApproval"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_background_warning"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/approvalRiskLevel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RISK LEVEL: CRITICAL"
                android:textColor="#EF4444"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/approvalActionTag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Action: [SHUTDOWN]"
                android:textColor="#94A3B8"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="10dp" />

            <TextView
                android:id="@+id/approvalDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ARIA wants to perform this action on your system."
                android:textColor="#F1F5F9"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/approvalTimestamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Requested just now"
                android:textColor="#64748B"
                android:textSize="11sp"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnApproveRequest"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginRight="6dp"
                    android:backgroundTint="#00E5FF"
                    android:text="✅  Approve"
                    android:textColor="#05060F"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnRejectRequest"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginLeft="6dp"
                    android:backgroundTint="#EF4444"
                    android:text="❌  Reject"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- ── Tab 6: Career Monitor ── -->
    <LinearLayout
        android:id="@+id/layoutCareer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomNavigation"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Career Opportunities"
            android:textColor="#64748B"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <!-- Empty Placeholder -->
        <TextView
            android:id="@+id/textNoCareers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:gravity="center"
            android:text="No job opportunities bookmarked."
            android:textColor="#64748B"
            android:textSize="14sp"
            android:visibility="visible" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/layoutCareersContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <!-- Profile Insights Card -->
                <LinearLayout
                    android:id="@+id/layoutProfileInsights"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="20dp"
                    android:background="@drawable/bg_insights_card"
                    android:padding="16dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Profile Insights"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <!-- Strengths Section -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="STRENGTHS"
                        android:textColor="#64748B"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:id="@+id/containerStrengths"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="16dp" />

                    <!-- Focus Chips Section -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CURRENT FOCUS"
                        android:textColor="#64748B"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:id="@+id/containerFocusChips"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp" />

                    <!-- Recent Updates Section -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RECENT CHANGES"
                        android:textColor="#64748B"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:id="@+id/containerLedger"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                </LinearLayout>

            </LinearLayout>

        </ScrollView>

    </LinearLayout>

    <!-- ── Tab 2: Document Scanner ── -->
    <ScrollView
        android:id="@+id/layoutScanner"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomNavigation"
        android:fillViewport="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mobile OCR Document Scanner"
                android:textColor="#64748B"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_insights_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <!-- Capture Buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <Button
                        android:id="@+id/btnScanCamera"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginRight="6dp"
                        android:backgroundTint="#00E5FF"
                        android:text="📸 Camera"
                        android:textColor="#05060F"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/btnScanGallery"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginLeft="6dp"
                        android:backgroundTint="#334155"
                        android:text="🖼 Gallery"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- Image Preview and Quality Status -->
                <ImageView
                    android:id="@+id/scanPreviewImage"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:background="#0F172A"
                    android:scaleType="fitCenter"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/textOcrConfidence"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#00E5FF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"
                    android:gravity="center"
                    android:visibility="gone" />

                <!-- Title Input -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DOCUMENT TITLE"
                    android:textColor="#64748B"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/editScanTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:backgroundTint="#334155"
                    android:hint="Enter note title..."
                    android:textColor="#F1F5F9"
                    android:textColorHint="#475569"
                    android:textSize="14sp"
                    android:inputType="text"
                    android:maxLines="1"
                    android:layout_marginBottom="16dp" />

                <!-- Extracted Text Review -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EXTRACTED TEXT REVIEW"
                    android:textColor="#64748B"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/editScanText"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:background="#0F172A"
                    android:gravity="top|left"
                    android:hint="Extracted OCR text will appear here. You can edit it before saving."
                    android:textColor="#CBD5E1"
                    android:textColorHint="#475569"
                    android:textSize="12sp"
                    android:inputType="textMultiLine"
                    android:scrollbars="vertical"
                    android:padding="8dp"
                    android:layout_marginBottom="16dp" />

                <!-- Ingest Button -->
                <Button
                    android:id="@+id/btnIngestScan"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:backgroundTint="#00E5FF"
                    android:text="📥 Ingest to Knowledge Vault"
                    android:textColor="#05060F"
                    android:textStyle="bold"
                    android:enabled="false" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- ── Bottom Navigation View ── -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#0D0E15"
        app:itemIconTint="#A3B8CC"
        app:itemTextColor="#A3B8CC" />

</RelativeLayout>
