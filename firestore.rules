rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Phone can READ laptop status (so it shows online/offline)
    match /status/{doc} {
      allow read: if true;
      allow write: if false; // only laptop writes this
    }

    // Phone can WRITE commands (so buttons work)
    match /commands/{doc} {
      allow write: if true;
      allow read: if false; // only laptop reads this
    }

    // Phone/Bridge can read and write health data
    match /health/{doc} {
      allow read, write: if true;
    }

    // Phone can write voice_audio metadata if user is "remote". Bypassed by laptop admin SDK.
    match /voice_audio/{doc} {
      allow write: if request.resource.data.user == "remote";
      allow read: if false;
    }

    // Allow read/write access to WebRTC sessions for signaling
    match /webrtc_sessions/{doc} {
      allow read, write: if true;
    }
  }
}
